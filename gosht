<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title>VR City Game</title>
    <script src="https://aframe.io/releases/1.5.0/aframe.min.js"></script>
    <script>
      var ghosts = 25;
      var coords;
      function toggle(t, s) {
        document.querySelector('a-scene').setAttribute('fog', 'far: 1');
        document.getElementById("txt").setAttribute('text', 'value: ' + t);
        setTimeout(function () {
          document.getElementById('cam1').setAttribute('active', 'false');
          document.getElementById('cam2').setAttribute('active', 'true');
        }, 3000);
        document.getElementById('player').setAttribute('src', s);
        document.getElementById("player").components.sound.playSound();
      } 
      AFRAME.registerComponent('colliding', {
        init: function () {
          coords = document.getElementById('cam1');
          this.el.sceneEl.addEventListener('enter-vr', function () { coords = document.getElementById('rig'); });
          this.el.sceneEl.addEventListener('exit-vr', function () { coords = document.getElementById('cam1'); });
        },
        tick: function () {
          var pos1 = coords.getAttribute('position');
          var pos2 = this.el.getAttribute('position');
          var rot = document.getElementById('spacecraft').getAttribute('rotation');
          if (Math.abs(pos1.x - pos2.x) < 48 && Math.abs(pos1.z - pos2.z) < 40) {
            toggle('GAME OVER', '#explode');
          }
          var distance = Math.sqrt(pos1.x * pos1.x + pos1.z * pos1.z);
          var angle = Math.atan2(pos1.x, pos1.z) * 180 / Math.PI;
          if (angle < 0) angle = 360 + angle;
          if ((Math.abs(rot.y - angle) < 38 || Math.abs(rot.y - angle) > 345) && distance > 5 && distance < 250) {
            toggle('GAME OVER', '#police');
          }
        }
      });
      AFRAME.registerComponent('ghosting', {
        init: function () {
          this.el.addEventListener('mouseenter', () => {
            document.getElementById('shot').components.sound.playSound();
            document.getElementById('laser').setAttribute('line', 'start: 0 -0.01 0; end: 0 0 -1; color: lime');
          });
            this.el.addEventListener('mouseleave', () => {
            document.getElementById('laser').removeAttribute('line');
            this.el.remove();
            ghosts--;
            if (ghosts <= 0) toggle('WELL DONE', '#scream');
          });
        },
        tick: function () {
          if (Math.random() < 0.99) return;
          var x = Math.random() * 700 - 350;
          var y = Math.random() * 50 + 10;
          var z = Math.random() * 700 - 350;
          this.el.setAttribute('animation', `property: position; to: ${x} ${y} ${z}; dur: 5000`);
        }
      });
    </script>
  </head>
  <body>
    <a-scene shadow="type: pcfsoft">
      <a-assets>
        <a-asset-item id="tree" src="tree.glb"></a-asset-item>
        <a-asset-item id="ghost" src="ghost.gltf"></a-asset-item>
        <a-asset-item id="craft" src="spacecraft.glb"></a-asset-item>
        <img id="stars" src="eso0932a.jpg">
        <img id="earth" src="flat_earth03.jpg">
        <img id="b1" src="b1.png"><img id="b2" src="b2.png"><img id="b3" src="b3.png">
        <img id="b4" src="b4.png"><img id="b5" src="b5.png"><img id="b6" src="b6.png">
        <audio id="gun" src="mixkit-short-laser-gun-shot-1670.wav"></audio>
        <audio id="explode" src="mixkit-explosion-in-battle-2809.wav"></audio>
        <audio id="police" src="mixkit-police-siren-us-1643.wav"></audio>
        <audio id="scream" src="mixkit-battle-man-scream-2175.wav"></audio>
        <a-box id="pavement" color="#333" width="80" height="0.5" depth="80" visible="false">
          <a-entity gltf-model="#tree" position="-35 0 25"></a-entity>
          <a-box color="#666" width="30" height="10" depth="30" position="0 5 0"></a-box>
        </a-box>
      </a-assets>
      <a-sky src="#stars" radius="5000" animation="property: rotation; to: 0 360 0; dur: 200000; loop: true"></a-sky>
      <a-sphere src="#earth" radius="1000" position="0 -1005 0" animation="property: rotation; to: 0 360 0; dur: 30000; loop: true"></a-sphere>
      <a-light type="ambient" intensity="0.2"></a-light>
      <a-light type="directional" intensity="0.5" position="1 1 1"></a-light>
      <a-entity id="rig" position="0 -20 4900" animation="property: position; to: 0 0 0; dur: 30000; easing: easeInOutQuad">
        <a-camera id="cam1" wasd-controls="acceleration: 500">
          <a-cursor color="lime"></a-cursor>
          <a-entity id="laser"></a-entity>
          <a-sound id="shot" src="#gun"></a-sound>
          <a-sound id="player"></a-sound>
        </a-camera>
      </a-entity>
      <a-entity id="spacecraft" gltf-model="#craft" scale="10 10 10" 
                animation="property: position; from: 0 60 0; to: 0 80
